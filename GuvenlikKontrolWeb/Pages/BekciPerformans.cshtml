@page
@model GuvenlikKontrolWeb.Pages.BekciPerformansModel
@{
    ViewData["Title"] = "Bekçi Performans Raporu";
}

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold m-0"><i class="bi bi-person-badge me-2"></i>Bekçi Performans Analizi</h2>
        <div id="tarihGosterge" class="badge bg-light text-dark border p-2"></div>
    </div>

    <div id="statusInfo" class="alert alert-info shadow-sm border-start border-info border-4">
        <i class="bi bi-info-circle-fill me-2"></i>Lütfen sol menüden tarih seçip "Raporu Güncelle" butonuna basınız.
    </div>

    <div class="row">
        <div class="col-xl-12 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header py-3 bg-white d-flex align-items-center">
                    <h6 class="m-0 font-weight-bold text-success"><i class="bi bi-bar-chart-line me-2"></i>Başarı Oranı Karşılaştırması (%)</h6>
                </div>
                <div class="card-body">
                    <div style="height: 350px; width: 100%;">
                        <canvas id="perfChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-12">
            <div class="card shadow-sm border-0">
                <div class="card-header py-3 bg-dark text-white">
                    <h6 class="m-0 font-weight-bold"><i class="bi bi-table me-2"></i>Performans Detay Verileri</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="perfTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Bekçi Adı</th>
                                    <th class="text-center">Toplam Tur</th>
                                    <th class="text-center">Eksiksiz Tur</th>
                                    <th class="text-center">Eksikli Tur</th>
                                    <th class="text-center">Eksik Nokta</th>
                                    <th class="text-center">Başarı Oranı</th>
                                </tr>
                            </thead>
                            <tbody id="perfBody">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function () {
            // Sayfa açılır açılmaz veriyi çek
            veriyiYukle();

            // Sol menüdeki butona basıldığında Layout sayfayı reload ediyor.
            // Ama biz ne olur ne olmaz butonu burada da dinleyelim.
            $(document).on('click', '#btnRapor', function () {
                setTimeout(veriyiYukle, 1000);
            });
        });

        async function veriyiYukle() {
            // 1. Önce hafızayı (Session) kontrol et
            let rawData = sessionStorage.getItem("performansData");

            // 2. Hafıza boşsa veya veri yoksa API'ye "ZORLA" git
            if (!rawData || rawData === "[]") {
                console.log("Hafıza boş, API'den taze veri isteniyor...");

                // Menüdeki tarihleri al, yoksa localStorage'dakileri dene
                const bas = $("#menuBas").val() || localStorage.getItem("baslangic");
                const bit = $("#menuBit").val() || localStorage.getItem("bitis");

                if (bas && bit) {
                    try {
                        // API'ye taze istek atıyoruz
                        const res = await fetch(`/api/BekciPerformans?baslangic=${encodeURIComponent(bas)}&bitis=${encodeURIComponent(bit)}`);
                        if (res.ok) {
                            const data = await res.json();
                            if(data && data.length > 0) {
                                sessionStorage.setItem("performansData", JSON.stringify(data));
                                rawData = JSON.stringify(data);
                            }
                        }
                    } catch (err) {
                        console.error("API Bağlantı Hatası:", err);
                    }
                }
            }

            // 3. Veri geldiyse (Hafızadan veya API'den) işle
            if (rawData && rawData !== "[]") {
                const data = JSON.parse(rawData);
                $("#statusInfo").hide();
                tabloyuDoldur(data);
                grafikleriCiz(data);
            } else {
                // Hâlâ veri yoksa hata mesajını göster
                $("#perfBody").html('<tr><td colspan="6" class="text-center text-danger fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Veri bulunamadı. Lütfen tarih seçip "Raporu Güncelle" butonuna basınız.</td></tr>');
            }
        }

        function tabloyuDoldur(data) {
            let rows = "";
            data.forEach(item => {
                // API'den gelen verinin property isimlerini garantiye alıyoruz
                const ad = item.BekciAdi || item.bekciAdi || "---";
                const toplam = item.ToplamTur ?? item.toplamTur ?? 0;
                const eksiksiz = item.EksiksizTur ?? item.eksiksizTur ?? 0;
                const eksikli = item.EksikliTur ?? item.eksikliTur ?? 0;
                const eksikNokta = item.EksikNokta ?? item.eksikNokta ?? 0;
                const oran = item.BasariOrani ?? item.basariOrani ?? 0;

                rows += `<tr>
                    <td class="ps-4 fw-bold text-primary">${ad}</td>
                    <td class="text-center">${toplam}</td>
                    <td class="text-center text-success">${eksiksiz}</td>
                    <td class="text-center text-warning">${eksikli}</td>
                    <td class="text-center text-danger">${eksikNokta}</td>
                    <td class="text-center">
                        <span class="badge ${oran > 80 ? 'bg-success' : 'bg-warning'} text-white">
                            %${oran}
                        </span>
                    </td>
                </tr>`;
            });
            $("#perfBody").html(rows);
        }

        function grafikleriCiz(data) {
            const ctx = document.getElementById('perfChart')?.getContext('2d');
            if (!ctx) return;

            let existingChart = Chart.getChart("perfChart");
            if (existingChart) existingChart.destroy();

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.map(x => x.BekciAdi || x.bekciAdi),
                    datasets: [{
                        label: 'Başarı Oranı (%)',
                        data: data.map(x => x.BasariOrani || x.basariOrani),
                        backgroundColor: 'rgba(13, 110, 253, 0.6)',
                        borderColor: '#0d6efd',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, max: 100 } }
                }
            });
        }
    </script>
}